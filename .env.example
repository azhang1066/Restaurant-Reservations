# Resy API Credentials
# Extract these from your browser while logged into resy.com
# Steps:
#   1. Log in to resy.com
#   2. Open DevTools (F12)
#   3. Go to Application > Cookies > https://resy.com
#   4. Look for authToken cookie (starts with eyJ...)
#   5. Also check Network tab for x-resy-auth-token header in API calls
RESY_API_KEY=your_resy_api_key_here
RESY_AUTH_TOKEN=your_resy_auth_token_here

# SMTP Email Configuration
# For Gmail: use app password (not regular password)
# Generate app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=notify@example.com
FROM_EMAIL=

# Push Notifications
# Provider: "ntfy" (default, free, no account) or "pushover"
NOTIFY_PROVIDER=ntfy

# ntfy — free, open-source push notifications (https://ntfy.sh)
# Install the ntfy app and subscribe to your topic URL: ntfy.sh/{NTFY_TOPIC}
# The topic is auto-generated by the dashboard on first run if left empty.
NTFY_TOPIC=resy-notifier-

# Pushover (optional, alternative to ntfy)
# Sign up at https://pushover.net, create an application, then fill in:
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Channel toggles
NOTIFY_VIA_PUSH=true
NOTIFY_VIA_EMAIL=true

# Legacy Pushover fields (still used by main.py standalone mode)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Application Configuration (optional)
# Log level: DEBUG, INFO, WARNING, ERROR
# Defaults to INFO if not specified
# LOG_LEVEL=INFO

# Dry run mode: Set to true to log API calls without sending notifications
# Useful for testing your setup
# DRY_RUN=false